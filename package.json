{
  "type": "module",
  "private": true,
  "workspaces": ["packages/*", "playground"],
  "scripts": {
    "build": "tsdown",
    "test": "for pkg in packages/*/; do (cd \"$pkg\" && bun run test); done",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "docgen": "for pkg in packages/*/; do (cd \"$pkg\" && bun run docgen); done",
    "playground:dev": "bun run --cwd playground dev",
    "playground:build": "bun run --cwd playground build",
    "playground:sync": "bun run --cwd playground sync",
    "playground:open:android": "bun run --cwd playground open:android",
    "playground:run:android": "bun run --cwd playground run:android",
    "playground:open:ios": "bun run --cwd playground open:ios",
    "playground:run:ios": "bun run --cwd playground run:ios",
    "release:battery": "bun run --cwd packages/battery release",
    "release:sensors": "bun run --cwd packages/sensors release",
    "release:systeminfo": "bun run --cwd packages/systeminfo release"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.6.0",
    "tsdown": "^0.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
