{
  "name": "@danyalwe/capacitor-systeminfo",
  "version": "1.0.1",
  "description": "Capacitor plugin for device system information",
  "author": "danyalwe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zAlweNy26/capacitor-plugins.git"
  },
  "bugs": {
    "url": "https://github.com/zAlweNy26/capacitor-plugins/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "Package.swift",
    "Systeminfo.podspec",
    "android/",
    "dist/",
    "ios/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "xcodebuild -scheme Systeminfo -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api SystemInfoPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "tsdown",
    "test": "vitest run",
    "watch": "tsc --watch",
    "release": "commit-and-tag-version --path . --tag-prefix \"capacitor-systeminfo@\""
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "dependencies": {
    "platform": "^1.3.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/docgen": "^0.3.1",
    "@capacitor/ios": "^8.4.1",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@types/platform": "^1.3.6",
    "prettier": "^3.9.5",
    "prettier-plugin-java": "^2.10.2",
    "swiftlint": "^2.0.0",
    "tsdown": "^0.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
